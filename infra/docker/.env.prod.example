# Copy to .env.prod and fill in real values before deploying.
# Never commit .env.prod to git.
# Without a domain in v1, ProofForge is published on high ports behind its own
# internal nginx. The app relies on HTTPS because session cookies are Secure.

# Compose-level vars (used in compose.prod.yml interpolation)
IMAGE_NAMESPACE=sidnevart
IMAGE_TAG=latest
POSTGRES_USER=proofforge
POSTGRES_PASSWORD=change-me-strong-password
S3_ACCESS_KEY_ID=change-me
S3_SECRET_ACCESS_KEY=change-me-strong-key
S3_BUCKET=proofforge

# App env — read by api and worker containers via env_file
APP_ENV=production
APP_NAME=proofforge
APP_HOST=0.0.0.0
APP_PORT=8080

WEB_ORIGIN=https://80.74.25.43:18443
NEXT_PUBLIC_API_BASE_URL=https://80.74.25.43:18443

DB_MAX_CONNS=20
DB_MIN_CONNS=2
DB_MAX_CONN_LIFETIME=1h
DB_MAX_CONN_IDLE_TIME=15m
DB_HEALTHCHECK_TIMEOUT=3s
DB_RUN_MIGRATIONS=true

SESSION_COOKIE_NAME=pf_session
SESSION_TTL=720h

INVITE_TTL=168h

S3_REGION=us-east-1
S3_BUCKET=proofforge
S3_ACCESS_KEY_ID=change-me
S3_SECRET_ACCESS_KEY=change-me-strong-key
S3_USE_PATH_STYLE=true

OPENAI_API_KEY=change-me
OPENAI_MODEL=gpt-5.4

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_BASE_URL=
TELEGRAM_WEBHOOK_SECRET=change-me-random-32-chars

SMTP_HOST=change-me
SMTP_PORT=587
SMTP_USERNAME=change-me
SMTP_PASSWORD=change-me
SMTP_FROM=noreply@proof-forge.local

WORKER_RECAP_SWEEP_INTERVAL=1h

LOG_LEVEL=info
LOG_FORMAT=json

HTTP_READ_HEADER_TIMEOUT=5s
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=15s

REDIS_URL=redis://redis:6379/0
