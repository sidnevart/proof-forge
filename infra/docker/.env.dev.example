# Copy to .env.dev and fill in real values before starting the local stack.
# Never commit .env.dev to git.

APP_ENV=development
APP_NAME=proofforge
APP_HOST=0.0.0.0
APP_PORT=8080
HTTP_READ_HEADER_TIMEOUT=5s
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=10s

# Frontend talks to the host-mapped API port.
WEB_ORIGIN=http://localhost:3003
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

DB_MAX_CONNS=10
DB_MIN_CONNS=1
DB_MAX_CONN_LIFETIME=1h
DB_MAX_CONN_IDLE_TIME=15m
DB_HEALTHCHECK_TIMEOUT=3s
DB_RUN_MIGRATIONS=true

SESSION_COOKIE_NAME=pf_session
SESSION_TTL=720h

INVITE_TTL=168h

# MinIO object storage for file evidence.
S3_BUCKET=proofforge-dev
S3_REGION=us-east-1
S3_USE_PATH_STYLE=true
S3_ACCESS_KEY_ID=proofforge
S3_SECRET_ACCESS_KEY=proofforge123

# Leave empty to disable OpenAI-powered weekly recaps.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Leave empty to disable Telegram webhook.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_BASE_URL=
TELEGRAM_WEBHOOK_SECRET=dev-secret-not-used

# Leave empty to disable SMTP email.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@proof-forge.local

WORKER_RECAP_SWEEP_INTERVAL=1m

LOG_LEVEL=debug
LOG_FORMAT=json
