APP_ENV=development
APP_NAME=proofforge
APP_HOST=0.0.0.0
APP_PORT=8080
HTTP_READ_HEADER_TIMEOUT=5s
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=10s
WEB_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

DATABASE_URL=postgres://proofforge:proofforge@localhost:55432/proofforge?sslmode=disable
TEST_DATABASE_URL=postgres://proofforge:proofforge@localhost:55432/proofforge?sslmode=disable
DB_MAX_CONNS=10
DB_MIN_CONNS=1
DB_MAX_CONN_LIFETIME=1h
DB_MAX_CONN_IDLE_TIME=15m
DB_HEALTHCHECK_TIMEOUT=3s
DB_RUN_MIGRATIONS=true
SESSION_COOKIE_NAME=pf_session
SESSION_TTL=720h
INVITE_TTL=168h
REDIS_URL=redis://localhost:6379/0

# Object storage — leave S3_BUCKET empty to disable file evidence uploads.
# PRIVACY: The bucket MUST be private (no public read). All object access is
# mediated through the API. Presigned download URLs are a follow-up item;
# until then, evidence files are accessible only to users who can list the
# check-in via authenticated API (owner + buddy).
S3_BUCKET=proofforge-dev
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
# Set to true for MinIO and any path-style S3-compatible store.
S3_USE_PATH_STYLE=true
S3_ACCESS_KEY_ID=change-me
S3_SECRET_ACCESS_KEY=change-me

TELEGRAM_BOT_TOKEN=change-me
TELEGRAM_WEBHOOK_BASE_URL=https://example.com
TELEGRAM_WEBHOOK_SECRET=change-me

OPENAI_API_KEY=change-me
AI_RECAP_MODEL=gpt-5.4

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

LOG_LEVEL=debug
LOG_FORMAT=json
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
GRAFANA_URL=http://localhost:3001
WORKER_RECAP_SWEEP_INTERVAL=1m

ANALYTICS_PROVIDER=posthog
ANALYTICS_API_KEY=change-me
