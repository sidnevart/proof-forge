# ProofForge dev environment
APP_ENV=development
APP_NAME=proofforge
WEB_ORIGIN=http://localhost:3003
LOG_LEVEL=debug
LOG_FORMAT=text

# Database (set via docker-compose environment block)
DB_RUN_MIGRATIONS=true
DB_MAX_CONNS=5
DB_MIN_CONNS=1

# Session
SESSION_COOKIE_NAME=pf_session
SESSION_TTL=720h

# Invite
INVITE_TTL=168h

# Storage (MinIO)
S3_BUCKET=proofforge-dev
S3_ACCESS_KEY_ID=proofforge
S3_SECRET_ACCESS_KEY=proofforge-secret
S3_REGION=us-east-1

# Worker
WORKER_RECAP_SWEEP_INTERVAL=1m

# AI (disabled by default — set OPENAI_API_KEY to enable)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
